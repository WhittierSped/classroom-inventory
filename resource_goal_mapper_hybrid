        function saveGoal() {
            const goalId = document.getElementById('modalGoalId').value.trim();
            const domain = document.getElementById('modalDomain').value;
            const description = document.getElementById('modalDescription').value.trim();
            
            // Get all checked subcategories
            const selectedSubcategories = Array.from(document.querySelectorAll('.subcategory-checkbox:checked'))
                .map(cb => cb.value);

            if (!goalId || !domain || !description) {
                alert('Please fill in all required fields (Goal ID, Domain, and Description)');
                return;
            }

            const goalData = {
                'Goal ID': goalId,
                'Domain': domain,
                'Goal/Objective Description': description
            };

            // Add subcategories array if any selected
            if (selectedSubcategories.length > 0) {
                goalData['Subcategories'] = selectedSubcategories;
            }

            if (editingGoalId) {
                // Edit existing
                const goalIndex = goals.findIndex(g => g['Goal ID'] === editingGoalId);
                if (goalIndex !== -1) {
                    goals[goalIndex] = goalData;
                }
            } else {
                // Add new
                if (goals.find(g => g['Goal ID'] === goalId)) {
                    alert('Goal ID already exists. Please use a unique ID.');
                    return;
                }
                
                goals.push(goalData);
            }

            localStorage.setItem('goals', JSON.stringify(goals));
            closeGoalModal();
            renderGoalList();
            renderGoalDomainFilter();
            
            showNotification(editingGoalId ? 'Goal updated!' : 'Goal added!');
        }

        function deleteGoal(goalId) {
            if (!confirm('Are you sure you want to delete this goal? This will also remove any resource mappings to this goal.')) {
                return;
            }

            // Remove goal
            goals = goals.filter(g => g['Goal ID'] !== goalId);
            
            // Remove mappings to this goal
            Object.keys(mappings).forEach(resourceId => {
                if (mappings[resourceId][goalId]) {
                    delete mappings[resourceId][goalId];
                }
            });

            localStorage.setItem('goals', JSON.stringify(goals));
            localStorage.setItem('resourceGoalMappings', JSON.stringify(mappings));
            
            currentGoal = null;
            renderGoalList();
            renderGoalDomainFilter();
            document.getElementById('goalEditorContent').innerHTML = '<div class="empty-state"><div class="empty-state-icon">👈</div><p>Select a goal to view details</p></div>';
            
            showNotification('Goal deleted');
        }

