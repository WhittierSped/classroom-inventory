        function saveAllData() {
            // Convert mappings to array format
            const mappingArray = [];
            
            for (const [resourceId, goalMappings] of Object.entries(mappings)) {
                const resource = resources.find(r => r['Resource ID'] === resourceId);
                if (!resource) continue;

                for (const [goalId, support] of Object.entries(goalMappings)) {
                    const goal = goals.find(g => g['Goal ID'] === goalId);
                    if (!goal) continue;

                    mappingArray.push({
                        "Resource ID": resourceId,
                        "Resource Name": resource['Resource Name'],
                        "Format": resource.Format,
                        "Goal ID": goalId,
                        "Goal Domain": goal.Domain,
                        "Goal Description": goal['Goal/Objective Description'],
                        "How Resource Supports Goal": support
                    });
                }
            }

            // Create complete export
            const exportData = {
                resources: resources,
                goals: goals,
                mappings: mappingArray
            };

            // Download
            const dataStr = JSON.stringify(exportData, null, 2);
            const dataBlob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(dataBlob);
            
            const link = document.createElement('a');
            link.href = url;
            link.download = 'classroom_inventory_data.json';
            link.click();

            showNotification('Data saved! File downloaded.');
        }

        function showNotification(message) {
            const notification = document.getElementById('saveNotification');
            notification.textContent = message;
            notification.classList.add('show');
            setTimeout(() => {
                notification.classList.remove('show');
            }, 3000);
        }

