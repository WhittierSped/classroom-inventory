<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resource-Goal Mapper + Goal Editor</title>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            /* Rainbow theme - Pink, Orange, Yellow, Green, Blue, Indigo, Violet */
            --rainbow-pink: #ec4899;
            --rainbow-orange: #f97316;
            --rainbow-yellow: #eab308;
            --rainbow-green: #10b981;
            --rainbow-blue: #3b82f6;
            --rainbow-indigo: #6366f1;
            --rainbow-violet: #8b5cf6;
            
            --primary: var(--rainbow-indigo);
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: var(--rainbow-pink);
            --success: var(--rainbow-green);
            --warning: var(--rainbow-orange);
            --bg: #fafaf9;
            --surface: #ffffff;
            --text: #1c1917;
            --text-muted: #78716c;
            --border: #e7e5e4;
            --shadow: rgba(0, 0, 0, 0.08);
            
            /* Domain colors for goal cards */
            --domain-math: var(--rainbow-yellow);
            --domain-literacy: var(--rainbow-violet);
            --domain-sel: var(--rainbow-pink);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        .header {
            background: linear-gradient(135deg, 
                var(--rainbow-pink) 0%, 
                var(--rainbow-orange) 20%, 
                var(--rainbow-yellow) 40%, 
                var(--rainbow-green) 60%, 
                var(--rainbow-blue) 80%, 
                var(--rainbow-violet) 100%);
            color: white;
            padding: 2rem 1.5rem;
            box-shadow: 0 4px 6px -1px var(--shadow);
        }

        .header h1 {
            font-family: 'Fredoka', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .header p {
            opacity: 0.95;
            font-size: 0.95rem;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .mode-toggle {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .mode-btn {
            padding: 1rem 2rem;
            border: 2px solid var(--border);
            background: var(--surface);
            border-radius: 12px;
            cursor: pointer;
            font-weight: 700;
            transition: all 0.2s;
            font-size: 1rem;
            font-family: 'Fredoka', sans-serif;
        }

        .mode-btn:hover {
            border-color: var(--secondary);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px var(--shadow);
        }

        .mode-btn.active {
            background: var(--secondary);
            color: white;
            border-color: var(--secondary);
        }

        .toolbar {
            background: var(--surface);
            padding: 1.5rem;
            border-radius: 16px;
            box-shadow: 0 2px 8px var(--shadow);
            margin-bottom: 2rem;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px var(--shadow);
        }

        .btn-success {
            background: var(--success);
            color: white;
        }

        .btn-success:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px var(--shadow);
        }

        .btn-secondary {
            background: var(--secondary);
            color: white;
        }

        .btn-secondary:hover {
            background: #be185d;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px var(--shadow);
        }

        .search-box {
            padding: 0.75rem 1.25rem;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 0.95rem;
            font-family: 'DM Sans', sans-serif;
            flex: 1;
            min-width: 250px;
        }

        .search-box:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .progress-bar {
            background: var(--surface);
            padding: 1rem 1.5rem;
            border-radius: 12px;
            box-shadow: 0 2px 8px var(--shadow);
            margin-bottom: 2rem;
        }

        .progress-label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .progress-track {
            height: 12px;
            background: var(--bg);
            border-radius: 6px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--success) 0%, #34d399 100%);
            transition: width 0.3s;
        }

        .main-grid {
            display: grid;
            grid-template-columns: 400px 1fr;
            gap: 2rem;
        }

        @media (max-width: 1200px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background: var(--surface);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px var(--shadow);
        }

        .panel-title {
            font-family: 'Fredoka', sans-serif;
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--primary-dark);
        }

        .resource-list, .goal-list {
            max-height: 70vh;
            overflow-y: auto;
        }

        .resource-item, .goal-item {
            padding: 1rem;
            background: var(--bg);
            border: 2px solid var(--border);
            border-radius: 10px;
            margin-bottom: 0.75rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .resource-item:hover, .goal-item:hover {
            border-color: var(--primary-light);
            transform: translateX(4px);
        }

        .resource-item.active, .goal-item.active {
            border-color: var(--secondary);
            background: linear-gradient(135deg, rgba(236, 72, 153, 0.05) 0%, rgba(236, 72, 153, 0.1) 100%);
        }

        .resource-id, .goal-id {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: var(--secondary);
            color: white;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .goal-id {
            background: var(--primary);
        }

        .resource-name, .goal-name {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .resource-meta, .goal-meta {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .format-badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-right: 0.5rem;
        }

        .format-Digital {
            background: #e0e7ff;
            color: #3730a3;
        }

        .format-Physical {
            background: #fef3c7;
            color: #92400e;
        }

        .domain-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .domain-Math {
            background: rgba(234, 179, 8, 0.15);
            color: #854d0e;
        }

        .domain-Literacy {
            background: rgba(139, 92, 246, 0.15);
            color: #5b21b6;
        }

        .domain-Behavior, .domain-SEL, .domain-Communication {
            background: rgba(236, 72, 153, 0.15);
            color: #9f1239;
        }

        .editor-section {
            margin-bottom: 2rem;
        }

        .editor-header {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 1rem;
            color: var(--text);
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text);
        }

        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .form-textarea {
            resize: vertical;
            min-height: 100px;
        }

        .goals-grid {
            display: grid;
            gap: 1rem;
        }

        .goal-checkbox-item {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 1rem;
            background: var(--bg);
            border: 2px solid var(--border);
            border-radius: 10px;
            transition: all 0.2s;
        }

        .goal-checkbox-item:hover {
            border-color: var(--primary-light);
        }

        .goal-checkbox-item.checked {
            border-color: var(--success);
            background: rgba(16, 185, 129, 0.05);
        }

        .checkbox-wrapper {
            display: flex;
            align-items: center;
            margin-top: 0.25rem;
        }

        .checkbox {
            width: 24px;
            height: 24px;
            cursor: pointer;
            accent-color: var(--success);
        }

        .goal-info {
            flex: 1;
        }

        .goal-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .goal-desc {
            font-size: 0.9rem;
            color: var(--text);
            margin-bottom: 0.75rem;
        }

        .support-input {
            width: 100%;
            padding: 0.75rem;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            resize: vertical;
            min-height: 60px;
        }

        .support-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .support-input::placeholder {
            color: var(--text-muted);
            font-style: italic;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--text-muted);
        }

        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.3;
        }

        .stats {
            display: flex;
            gap: 2rem;
            margin-bottom: 1rem;
        }

        .stat-item {
            font-size: 0.9rem;
        }

        .stat-number {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.5rem;
        }

        .stat-label {
            color: var(--text-muted);
        }

        .domain-filter {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .filter-pill {
            padding: 0.4rem 1rem;
            background: var(--bg);
            border: 2px solid var(--border);
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .filter-pill:hover {
            border-color: var(--primary);
        }

        .filter-pill.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .save-notification {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--success);
            color: white;
            padding: 1rem 2rem;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            font-weight: 600;
            transform: translateY(150%);
            transition: transform 0.3s;
            z-index: 1000;
        }

        .save-notification.show {
            transform: translateY(0);
        }

        .instructions {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            padding: 1.5rem;
            border-radius: 12px;
            margin-bottom: 2rem;
            border-left: 4px solid var(--warning);
        }

        .instructions h3 {
            font-family: 'Fredoka', sans-serif;
            color: #92400e;
            margin-bottom: 0.75rem;
        }

        .instructions ol, .instructions ul {
            margin-left: 1.5rem;
            color: #78350f;
        }

        .instructions li {
            margin-bottom: 0.5rem;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal {
            background: var(--surface);
            border-radius: 16px;
            padding: 2rem;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            font-family: 'Fredoka', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--primary-dark);
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
            justify-content: flex-end;
        }

        .btn-ghost {
            background: transparent;
            border: 2px solid var(--border);
            color: var(--text);
        }

        .btn-ghost:hover {
            background: var(--bg);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .btn-small {
            padding: 0.4rem 0.75rem;
            font-size: 0.85rem;
        }

        .btn-danger {
            background: #ef4444;
            color: white;
        }

        .btn-danger:hover {
            background: #dc2626;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🔗 Resource & Goal Manager</h1>
        <p>Add goals, map resources, and build your complete classroom inventory</p>
    </div>

    <div class="container">
        <div class="mode-toggle">
            <button class="mode-btn active" onclick="setMode('mapping')">📋 Map Resources to Goals</button>
            <button class="mode-btn" onclick="setMode('goals')">➕ Add/Edit Goals</button>
        </div>

        <div id="mappingMode">
            <div class="instructions">
                <h3>Mapping Mode Instructions:</h3>
                <ol>
                    <li>Select a resource from the left panel</li>
                    <li>Check the boxes for goals it supports</li>
                    <li>For each checked goal, describe how the resource supports it</li>
                    <li>Click "Save All Data" to download</li>
                </ol>
            </div>

            <div class="progress-bar">
                <div class="progress-label">Mapping Progress: <span id="progressText">0 resources mapped</span></div>
                <div class="progress-track">
                    <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                </div>
            </div>

            <div class="toolbar">
                <input type="text" class="search-box" id="resourceSearch" placeholder="🔍 Search resources...">
                <div style="display: flex; gap: 1rem;">
                    <button class="btn btn-secondary" onclick="openAddResourceModal()">➕ Add New Resource</button>
                    <button class="btn btn-primary" onclick="clearCurrentMappings()">Clear This Resource</button>
                    <button class="btn btn-success" onclick="saveAllData()">💾 Save All Data</button>
                </div>
            </div>

            <div class="main-grid">
                <div class="panel">
                    <div class="panel-title">Resources</div>
                    <div class="stats">
                        <div class="stat-item">
                            <div class="stat-number" id="totalResources">140</div>
                            <div class="stat-label">Total</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" id="mappedResources">0</div>
                            <div class="stat-label">Mapped</div>
                        </div>
                    </div>
                    <div class="resource-list" id="resourceList"></div>
                </div>

                <div class="panel">
                    <div class="panel-title" id="editorTitle">Select a resource to begin</div>
                    <div id="editorContent"></div>
                </div>
            </div>
        </div>

        <div id="goalsMode" style="display: none;">
            <div class="instructions">
                <h3>Goal Management Instructions:</h3>
                <ul>
                    <li><strong>Add New Goal:</strong> Click "Add New Goal" button</li>
                    <li><strong>Edit Goal:</strong> Click on any goal in the list</li>
                    <li><strong>Delete Goal:</strong> Click the delete button on a goal</li>
                    <li><strong>Save:</strong> Click "Save All Data" when done</li>
                </ul>
            </div>

            <div class="toolbar">
                <input type="text" class="search-box" id="goalSearch" placeholder="🔍 Search goals...">
                <div style="display: flex; gap: 1rem;">
                    <button class="btn btn-secondary" onclick="openAddGoalModal()">➕ Add New Goal</button>
                    <button class="btn btn-success" onclick="saveAllData()">💾 Save All Data</button>
                </div>
            </div>

            <div class="main-grid">
                <div class="panel">
                    <div class="panel-title">IEP Goals</div>
                    <div class="stats">
                        <div class="stat-item">
                            <div class="stat-number" id="totalGoals">85</div>
                            <div class="stat-label">Total Goals</div>
                        </div>
                    </div>
                    <div class="domain-filter" id="goalDomainFilter"></div>
                    <div class="goal-list" id="goalList"></div>
                </div>

                <div class="panel">
                    <div class="panel-title" id="goalEditorTitle">Select a goal to edit</div>
                    <div id="goalEditorContent"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add/Edit Goal Modal -->
    <div class="modal-overlay" id="goalModal">
        <div class="modal">
            <div class="modal-header" id="modalTitle">Add New Goal</div>
            <div class="form-group">
                <label class="form-label">Goal ID *</label>
                <input type="text" class="form-input" id="modalGoalId" placeholder="e.g., G086">
            </div>
            <div class="form-group">
                <label class="form-label">Domain *</label>
                <select class="form-select" id="modalDomain" onchange="updateSubcategoryOptions()">
                    <option value="">Select a domain...</option>
                    <option value="Math">Math</option>
                    <option value="Literacy">Literacy</option>
                    <option value="SEL">SEL</option>
                </select>
            </div>
            <div class="form-group" id="subcategoryGroup" style="display: none;">
                <label class="form-label">Subcategories (select all that apply)</label>
                <div id="subcategoryCheckboxes" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.5rem; padding: 0.75rem; background: var(--bg); border-radius: 8px;">
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Goal/Objective Description *</label>
                <textarea class="form-textarea" id="modalDescription" placeholder="Describe the goal or objective..."></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn btn-ghost" onclick="closeGoalModal()">Cancel</button>
                <button class="btn btn-success" onclick="saveGoal()">Save Goal</button>
            </div>
        </div>
    </div>

    <!-- Add/Edit Resource Modal -->
    <div class="modal-overlay" id="resourceModal">
        <div class="modal">
            <div class="modal-header" id="resourceModalTitle">Add New Resource</div>
            <div class="form-group">
                <label class="form-label">Resource ID *</label>
                <input type="text" class="form-input" id="modalResourceId" placeholder="e.g., D141 or P023">
            </div>
            <div class="form-group">
                <label class="form-label">Resource Name *</label>
                <input type="text" class="form-input" id="modalResourceName" placeholder="e.g., Number Line Activities">
            </div>
            <div class="form-group">
                <label class="form-label">Format *</label>
                <select class="form-select" id="modalResourceFormat">
                    <option value="">Select format...</option>
                    <option value="Digital">Digital</option>
                    <option value="Physical">Physical</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <input type="text" class="form-input" id="modalResourceCategory" placeholder="e.g., Math, Literacy, SEL/Behavior">
            </div>
            <div class="form-group">
                <label class="form-label">Quantity</label>
                <input type="text" class="form-input" id="modalResourceQuantity" placeholder="e.g., 1, Class Set, Multiple">
            </div>
            <div class="form-group">
                <label class="form-label">Location/File Path</label>
                <input type="text" class="form-input" id="modalResourceLocation" placeholder="e.g., TPT/Math, Math Cabinet, Shelf 3">
            </div>
            <div class="form-group">
                <label class="form-label">Description/Notes</label>
                <textarea class="form-input" id="modalResourceDescription" rows="3" placeholder="Brief description of the resource"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Source</label>
                <input type="text" class="form-input" id="modalResourceSource" placeholder="e.g., Teachers Pay Teachers, Lakeshore Learning, Amazon">
            </div>
            <div class="modal-actions">
                <button class="btn btn-ghost" onclick="closeResourceModal()">Cancel</button>
                <button class="btn btn-success" onclick="saveResource()">Save Resource</button>
            </div>
        </div>
    </div>

    <div class="save-notification" id="saveNotification">
        ✓ Data saved! File downloaded.
    </div>

    <script>
        // ============================================
        // GOOGLE SHEETS CONFIGURATION
        // ============================================
        // INSTRUCTIONS:
        // 1. Upload your classroom_inventory.xlsx to Google Sheets
        // 2. Click "Share" → "Anyone with the link can VIEW"
        // 3. Copy the Sheet ID from the URL (the long string between /d/ and /edit)
        //    Example URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
        // 4. Paste your Sheet ID below:
        
        const GOOGLE_SHEET_ID = '1LYczFajdWtN3qGOSlqayUpjbZQQUYZhapI4fzL7SUlQ';  // ← PASTE YOUR SHEET ID HERE
        
        // Sheet names (these match your Excel tabs - don't change unless you renamed them)
        const SHEET_NAMES = {
            resources: 'Resources Inventory',
            goals: 'IEP Goals',
            mappings: 'Resource-Goal Mapping'
        };
        
        // ============================================
        
        // Initialize empty - will be loaded from Google Sheets
        let resources = [];
        let goals = [];
        let mappings = {};
        let currentMode = 'mapping';
        let currentResource = null;
        let currentGoal = null;
        let domainFilter = 'all';
        let subcategoryFilter = 'all';
        let editingGoalId = null;

        // Subcategories for each domain
        const SUBCATEGORIES = {
            'Math': [
                'Counting/Cardinality',
                'Number Sense',
                'Fact Fluency',
                'Within 10',
                'Within 20',
                'Measurement',
                'Shapes',
                'Data/Graphing',
                'Place Value and Comparison',
