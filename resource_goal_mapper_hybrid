        async function fetchSheetData(sheetName) {
            const url = `https://docs.google.com/spreadsheets/d/${GOOGLE_SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(sheetName)}`;
            
            const response = await fetch(url);
            const text = await response.text();
            
            // Google Sheets returns JSONP, need to extract JSON
            const json = JSON.parse(text.substring(47).slice(0, -2));
            
            // Convert to array of objects
            const rows = json.table.rows;
            const cols = json.table.cols;
            
            // First row is headers
            const headers = cols.map(col => col.label);
            
            // Convert rows to objects
            return rows.map(row => {
                const obj = {};
                row.c.forEach((cell, index) => {
                    obj[headers[index]] = cell ? cell.v : '';
                });
                return obj;
            });
        }
        
        async function loadGoogleSheetsData() {
            try {
                const container = document.querySelector('.container');
                if (container) {
                    container.innerHTML = `
                        <div style="text-align: center; padding: 4rem 2rem;">
                            <div style="font-size: 4rem; margin-bottom: 1rem; animation: pulse 2s ease-in-out infinite;">🔗</div>
                            <h2 style="font-family: 'Fredoka', sans-serif; color: var(--primary); margin-bottom: 0.5rem;">Loading Your Data...</h2>
                            <p style="color: var(--text-muted);">Fetching from Google Sheets</p>
                            <style>
                                @keyframes pulse {
                                    0%, 100% { transform: scale(1); }
                                    50% { transform: scale(1.1); }
                                }
                            </style>
                        </div>
                    `;
                }
                
                // Fetch all three sheets in parallel
                const [resourcesData, goalsData, mappingsData] = await Promise.all([
                    fetchSheetData(SHEET_NAMES.resources),
                    fetchSheetData(SHEET_NAMES.goals),
                    fetchSheetData(SHEET_NAMES.mappings)
                ]);
                
                resources = resourcesData;
                goals = goalsData;
                
                // Convert mappings array to object format
                mappings = {};
                mappingsData.forEach(row => {
                    const resourceId = row['Resource ID'];
                    const goalId = row['Goal ID'];
                    const howSupported = row['How Resource Supports Goal'] || '';
                    
                    if (!mappings[resourceId]) {
                        mappings[resourceId] = {};
                    }
                    mappings[resourceId][goalId] = {
                        checked: true,
                        description: howSupported
                    };
                });
                
                // Restore page and initialize app
                document.body.innerHTML = document.body.innerHTML; // Reset
                window.location.reload(); // Reload to restore HTML
                
                initAppWithData();
                
            } catch (error) {
                console.error('Error loading data:', error);
                const container = document.querySelector('.container');
                if (container) {
                    container.innerHTML = `
                        <div style="text-align: center; padding: 4rem 2rem;">
                            <div style="font-size: 4rem; margin-bottom: 1rem;">❌</div>
                            <h2 style="font-family: 'Fredoka', sans-serif; color: #dc2626; margin-bottom: 1rem;">Unable to Load Data</h2>
                            <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.6;">
                                <strong>Possible issues:</strong><br><br>
                                1. Make sure your Google Sheet is set to "Anyone with the link can VIEW"<br>
                                2. Check that the Sheet ID is correct<br>
                                3. Verify your sheet tab names match exactly<br><br>
                                <strong>Error:</strong> ${error.message}
                            </p>
                            <button onclick="location.reload()" style="margin-top: 2rem; padding: 0.75rem 1.5rem; background: var(--primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">
                                Try Again
                            </button>
                        </div>
                    `;
                }
            }
        }

