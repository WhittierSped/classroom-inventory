                        <div class="filter-pill ${domainFilter === 'all' ? 'active' : ''}" onclick="setDomainFilterMapping('all')">All Domains</div>
                        ${domains.map(d => `
                            <div class="filter-pill ${domainFilter === d ? 'active' : ''}" onclick="setDomainFilterMapping('${d}')">${d}</div>
                        `).join('')}
                    </div>
                    ${domainFilter !== 'all' && SUBCATEGORIES[domainFilter] ? `
                        <div style="font-weight: 600; margin-bottom: 0.75rem; color: var(--text);">📌 Step 2: Narrow by subcategory (optional)</div>
                        <div class="domain-filter">
                            <div class="filter-pill ${subcategoryFilter === 'all' ? 'active' : ''}" onclick="setSubcategoryFilterMapping('all')">All ${domainFilter}</div>
                            ${SUBCATEGORIES[domainFilter].map(sc => `
                                <div class="filter-pill ${subcategoryFilter === sc ? 'active' : ''}" onclick="setSubcategoryFilterMapping('${sc}')">${sc}</div>
                            `).join('')}
                        </div>
                    ` : ''}
                </div>
            `;

            let filteredGoals = goals;
            if (domainFilter !== 'all') {
                filteredGoals = filteredGoals.filter(g => g.Domain === domainFilter);
            }
            if (subcategoryFilter !== 'all') {
                filteredGoals = filteredGoals.filter(g => {
                    if (g.Subcategories && Array.isArray(g.Subcategories)) {
                        return g.Subcategories.includes(subcategoryFilter);
                    } else if (g.Subcategory) {
                        return g.Subcategory === subcategoryFilter;
                    }
                    return false;
                });
            }

            const goalsHtml = filteredGoals.map(goal => {
                const isChecked = resourceMappings[goal['Goal ID']] !== undefined;
                const supportText = resourceMappings[goal['Goal ID']] || '';
                
                // Handle both array of subcategories and single subcategory
                let subcategoryBadges = '';
                if (goal.Subcategories && Array.isArray(goal.Subcategories)) {
                    subcategoryBadges = goal.Subcategories.map(sc => 
                        `<span class="domain-badge" style="background: #e9d5ff; color: #6b21a8; margin-left: 0.25rem; margin-top: 0.25rem; font-size: 0.7rem; display: inline-block;">${sc}</span>`
                    ).join('');
                } else if (goal.Subcategory) {
                    subcategoryBadges = `<span class="domain-badge" style="background: #e9d5ff; color: #6b21a8; margin-left: 0.25rem; font-size: 0.7rem;">${goal.Subcategory}</span>`;
                }
                
                return `
                    <div class="goal-checkbox-item ${isChecked ? 'checked' : ''}" id="goal-${goal['Goal ID']}">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" 
                                   class="checkbox" 
                                   id="check-${goal['Goal ID']}"
                                   ${isChecked ? 'checked' : ''}
                                   onchange="toggleGoal('${goal['Goal ID']}')">
                        </div>
                        <div class="goal-info">
                            <div class="goal-header" style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.25rem;">
                                <span class="goal-id">${goal['Goal ID']}</span>
                                <span class="domain-badge domain-${goal.Domain}">${goal.Domain}</span>
                                ${subcategoryBadges}
                            </div>
                            <div class="goal-desc">${goal['Goal/Objective Description']}</div>
                            <textarea class="support-input" 
                                      id="support-${goal['Goal ID']}"
                                      placeholder="How does this resource support this goal?"
                                      ${isChecked ? '' : 'disabled'}
                                      onchange="updateSupport('${goal['Goal ID']}')">${supportText}</textarea>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('editorContent').innerHTML = `
                ${resourceDetailHtml}
                ${filterHtml}
                <div class="editor-section">
                    <div class="editor-header">
                        📋 Select goals this resource supports 
                        <span style="font-weight: normal; color: var(--text-muted); margin-left: 0.5rem;">
                            (${filteredGoals.length} ${filteredGoals.length === 1 ? 'goal' : 'goals'} shown)
                        </span>
                    </div>
                    <div class="goals-grid">
                        ${goalsHtml}
                    </div>
                </div>
            `;
        }

        function setDomainFilterMapping(domain) {
            domainFilter = domain;
            subcategoryFilter = 'all'; // Reset subcategory when domain changes
            renderEditor();
        }

        function setSubcategoryFilterMapping(subcat) {
            subcategoryFilter = subcat;
            renderEditor();
        }

        function toggleGoal(goalId) {
            if (!mappings[currentResource]) {
                mappings[currentResource] = {};
            }

            const checkbox = document.getElementById(`check-${goalId}`);
            const textarea = document.getElementById(`support-${goalId}`);
            const container = document.getElementById(`goal-${goalId}`);

            if (checkbox.checked) {
                mappings[currentResource][goalId] = textarea.value || '';
                textarea.disabled = false;
                container.classList.add('checked');
                textarea.focus();
            } else {
                delete mappings[currentResource][goalId];
                textarea.disabled = true;
                textarea.value = '';
                container.classList.remove('checked');
            }

            saveMappingsToLocalStorage();
            updateProgress();
            renderResourceList(document.getElementById('resourceSearch').value);
        }

        function updateSupport(goalId) {
            if (!mappings[currentResource]) {
                mappings[currentResource] = {};
            }

            const textarea = document.getElementById(`support-${goalId}`);
            mappings[currentResource][goalId] = textarea.value;
            saveMappingsToLocalStorage();
        }

        function clearCurrentMappings() {
            if (!currentResource) return;
            
            if (confirm('Are you sure you want to clear all mappings for this resource?')) {
                delete mappings[currentResource];
                saveMappingsToLocalStorage();
                updateProgress();
                renderEditor();
                renderResourceList(document.getElementById('resourceSearch').value);
            }
        }

        function saveMappingsToLocalStorage() {
            localStorage.setItem('resourceGoalMappings', JSON.stringify(mappings));
        }

        function updateProgress() {
            const mappedCount = Object.keys(mappings).filter(k => Object.keys(mappings[k]).length > 0).length;
            const percentage = (mappedCount / resources.length) * 100;
            
            document.getElementById('mappedResources').textContent = mappedCount;
            document.getElementById('progressText').textContent = `${mappedCount} of ${resources.length} resources mapped`;
            document.getElementById('progressFill').style.width = `${percentage}%`;
        }

