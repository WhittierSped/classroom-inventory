<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Fact Fluency Sheet Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f5f3ee; --surface: #fff; --border: #d8d4cc; --border-light: #e8e4dc;
    --text: #1a1917; --text-secondary: #6b6760; --text-hint: #a09c97;
    --accent: #c90076; --accent-light: #ffe7f5; --radius: 6px;
  }
  body { font-family:'Lexend',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; padding:2rem 1rem 4rem; }
  .page { max-width:820px; margin:0 auto; }
  header { margin-bottom:2rem; }
  .logo { display:inline-flex; align-items:center; gap:10px; margin-bottom:.4rem; }
  .logo-mark { width:36px; height:36px; background:var(--accent); border-radius:8px; display:flex; align-items:center; justify-content:center; }
  h1 { font-size:22px; font-weight:600; letter-spacing:-.3px; }
  .subtitle { font-size:14px; color:var(--text-secondary); font-weight:300; margin-top:2px; }

  .card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1.5rem; margin-bottom:1.25rem; }
  .card-title { font-size:12px; font-weight:500; color:var(--text-secondary); text-transform:uppercase; letter-spacing:.06em; margin-bottom:1rem; }

  .row { display:flex; flex-wrap:wrap; gap:1rem; align-items:flex-start; }
  .field { display:flex; flex-direction:column; gap:6px; }
  .field label { font-size:12px; font-weight:500; color:var(--text-secondary); text-transform:uppercase; letter-spacing:.05em; }

  .chips { display:flex; flex-wrap:wrap; gap:6px; }
  .chip { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:20px; border:1px solid var(--border); background:var(--surface); font-family:'Lexend',sans-serif; font-size:13px; cursor:pointer; user-select:none; color:var(--text-secondary); transition:all .15s; }
  .chip.on { background:var(--accent); border-color:var(--accent); color:#fff; }
  .chip:hover:not(.on) { border-color:#aaa; color:var(--text); }


  /* Range option — shown/hidden based on operation */
  .range-field { display:none; }
  .range-field.visible { display:flex; }

  select { font-family:'Lexend',sans-serif; font-size:13px; padding:6px 10px; border:1px solid var(--border); border-radius:var(--radius); background:var(--surface); color:var(--text); outline:none; cursor:pointer; }
  select:focus { border-color:var(--accent); }

  .controls-row { display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-top:1.25rem; }
  button { font-family:'Lexend',sans-serif; font-size:13px; font-weight:500; padding:8px 18px; border-radius:var(--radius); cursor:pointer; outline:none; }
  .btn-primary { background:var(--accent); color:#fff; border:none; }
  .btn-primary:hover { background:#255234; }
  .btn-secondary { background:var(--surface); color:var(--text); border:1px solid var(--border); }
  .btn-secondary:hover { background:var(--bg); }
  .btn-secondary:disabled { opacity:.4; cursor:not-allowed; }

  .output-card { display:none; background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-bottom:1.25rem; }
  .output-header { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; border-bottom:1px solid var(--border-light); }
  .output-title { font-size:12px; font-weight:500; color:var(--text-secondary); text-transform:uppercase; letter-spacing:.06em; }
  .output-footer { padding:.75rem 1.5rem; border-top:1px solid var(--border-light); display:flex; gap:10px; }

  /* ── Sheet ── */
  .sheet { padding:1.5rem 2rem; font-family:'Lexend',sans-serif; }
  .sheet-header { display:flex; justify-content:flex-end; gap:1.5rem; margin-bottom:1.2rem; font-size:13px; color:var(--text-secondary); align-items:baseline; }
  .sheet-header-field { display:flex; align-items:baseline; gap:6px; white-space:nowrap; }
  .sheet-header-line { display:inline-block; border-bottom:1px solid var(--border); }
  .shl-name { width:2in; }
  .shl-date { width:1in; }

  .support-block { margin-bottom:.9rem; }

  /* Number line */
  .number-line-wrap { display:flex; justify-content:center; margin-bottom:.5rem; }
  .number-line { display:flex; align-items:stretch; border:1px solid #aaa; border-radius:3px; overflow:hidden; width:fit-content; }
  .nl-tick { width:32px; text-align:center; font-size:14px; padding:4px 0; border-right:1px solid #ccc; color:var(--text); font-family:'Lexend',sans-serif; font-weight:400; }
  .nl-tick:last-child { border-right:none; }

  .sheet-label {
    font-size:13px;
    font-weight:500;
    color:var(--text-secondary);
    margin-bottom:1rem;
    letter-spacing:.01em;
  }

  /* Problem grid */
  .problem-grid { display:grid; margin-top:2rem; }
  .prob-cell { display:flex; flex-direction:column; gap:5px; }
  .equation { display:flex; align-items:baseline; gap:6px; font-size:20px; font-weight:400; font-family:'Lexend',sans-serif; color:var(--text); }
  .eq-num { min-width:1.2ch; text-align:right; }
  .eq-op { font-weight:300; color:var(--text-secondary); }
  .eq-ans { display:inline-block; border-bottom:1.5px solid var(--text); min-width:1.3in; margin-left:4px; }

  /* Frames */
  .tf-wrap { display:flex; flex-direction:column; gap:6px; margin-top:4px; }
  .ten-frame { display:flex; flex-direction:column; gap:2px; }
  .five-frame { display:flex; flex-direction:row; gap:2px; margin-top:4px; }
  .tf-row { display:flex; gap:2px; }
  .tf-cell { width:36px; height:36px; border:1.5px solid #aaa; border-radius:3px; background:#fff; }
  .tf-cell.tall { width:36px; height:36px; } /* same size, used in five-frame */

  /* Tens & ones */
  .to-chart { display:inline-grid; grid-template-columns:auto auto; border:1px solid #aaa; border-radius:3px; overflow:hidden; font-size:11px; margin-top:2px; }
  .to-head { background:#f0f0ec; padding:2px 12px; text-align:center; font-weight:500; color:var(--text-secondary); border-bottom:1px solid #ccc; }
  .to-head:first-child { border-right:1px solid #ccc; }
  .to-body { padding:8px 12px; text-align:center; }
  .to-body:first-child { border-right:1px solid #ccc; }

  /* ── Print ── */
  @media print {
    @page { margin:.45in .65in; size:letter; }
    * { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    body { background:#fff; padding:0; margin:0; }
    body > * { display:none !important; }
    .page { display:block !important; max-width:100%; margin:0; padding:0; }
    .page > * { display:none !important; }
    .output-card { display:block !important; border:none !important; box-shadow:none !important; margin:0 !important; }
    .output-header, .output-footer { display:none !important; }
    .sheet { display:flex !important; flex-direction:column; padding:0; margin:0; min-height:9.6in; justify-content:flex-start; }
    .sheet-header { font-size:11pt; margin-bottom:.1in; flex-shrink:0; }
    .sheet-label { font-size:11pt; font-weight:500; margin-bottom:.15in; color:#444; }
    .sheet-header-line { border-bottom:1pt solid #000; }
    .shl-name { width:2in; }
    .shl-date { width:1in; }
    .problem-grid { flex:1; min-height:0; margin-top:.5in; }
    .problem-grid.spacing-fill { align-content:space-between; }
    .problem-grid.spacing-spread { align-content:space-around; }
    .equation { font-size:17pt; }
    .eq-ans { border-bottom:1.5pt solid #000; min-width:1.1in; }
    .tf-cell { width:30px; height:30px; }
    .number-line { border-color:#000; }
    .nl-tick { font-size:12pt; width:30px; padding:3px 0; border-right-color:#999; }
    .to-chart { border-color:#000; }
    .to-head { border-bottom-color:#999; }
    .to-head:first-child, .to-body:first-child { border-right-color:#999; }
  }
</style>
</head>
<body>
<div class="page">

  <header>
    <div class="logo">
      <div class="logo-mark">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <rect x="3" y="5" width="14" height="2.5" rx="1.25" fill="white" opacity=".9"/>
          <rect x="3" y="9" width="14" height="2.5" rx="1.25" fill="white" opacity=".6"/>
          <rect x="3" y="13" width="9" height="2.5" rx="1.25" fill="white" opacity=".35"/>
        </svg>
      </div>
      <h1>Fact Fluency Sheet Generator</h1>
    </div>
    <p class="subtitle">Addition &amp; Subtraction · CBM · One page · Up to 12 problems</p>
  </header>

  <!-- Operations -->
  <div class="card">
    <div class="card-title">Operations</div>
    <div class="row" style="gap:1.5rem;">
      <div class="field">
        <label>Primary operation</label>
        <div class="chips" id="op1-chips">
          <span class="chip on" onclick="pickOp(1,'+',this)">+ Addition</span>
          <span class="chip" onclick="pickOp(1,'-',this)">− Subtraction</span>

        </div>
      </div>
      <div class="field">
        <label>Mix with (optional)</label>
        <div class="chips" id="op2-chips">
          <span class="chip on" onclick="pickOp(2,'none',this)">None</span>
          <span class="chip" onclick="pickOp(2,'+',this)">+ Addition</span>
          <span class="chip" onclick="pickOp(2,'-',this)">− Subtraction</span>

        </div>
      </div>
    </div>

    <!-- Range options — shown when + or - is selected -->
    <div style="margin-top:1rem; display:flex; gap:1.5rem; flex-wrap:wrap;">
      <div class="field range-field visible" id="add-range-field">
        <label>Addition — sums up to</label>
        <div class="chips" id="add-range-chips">
          <span class="chip on" onclick="pickRange('add',5,this)">5</span>
          <span class="chip" onclick="pickRange('add',10,this)">10</span>
          <span class="chip" onclick="pickRange('add',20,this)">20</span>
        </div>
      </div>
      <div class="field range-field" id="sub-range-field">
        <label>Subtraction — within</label>
        <div class="chips" id="sub-range-chips">
          <span class="chip on" onclick="pickRange('sub',5,this)">5</span>
          <span class="chip" onclick="pickRange('sub',10,this)">10</span>
          <span class="chip" onclick="pickRange('sub',20,this)">20</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Numbers & Layout -->
  <div class="card">
    <div class="card-title">Numbers &amp; Layout</div>
    <div class="row" style="gap:2rem;">
<div class="field">
        <label>Problems per sheet</label>
        <select id="prob-count">
          <option value="6">6</option>
          <option value="8">8</option>
          <option value="10">10</option>
          <option value="12" selected>12</option>
        </select>
      </div>
      <div class="field">
        <label>Columns</label>
        <select id="layout">
          <option value="2">2 columns</option>
          <option value="3" selected>3 columns</option>
          <option value="4">4 columns</option>
        </select>
      </div>
      <div class="field">
        <label>Spacing</label>
        <select id="spacing">
          <option value="compact">Compact</option>
          <option value="normal" selected>Normal</option>
          <option value="spread">Spread out</option>
          <option value="full">Fill page</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Visual Supports -->
  <div class="card">
    <div class="card-title">Visual Supports (optional)</div>
    <div class="row" style="gap:2rem; align-items:flex-start;">
      <div class="field">
        <label>Per-problem</label>
        <div class="chips">
          <span class="chip" id="sup-fiveframe" onclick="toggleSupport('fiveframe',this)">Five-frame</span>
          <span class="chip" id="sup-tenframe1" onclick="toggleSupport('tenframe1',this)">1 Ten-frame</span>
          <span class="chip" id="sup-tenframe2" onclick="toggleSupport('tenframe2',this)">2 Ten-frames</span>
          <span class="chip" id="sup-tensones" onclick="toggleSupport('tensones',this)">Tens &amp; Ones</span>
        </div>
      </div>
      <div class="field">
        <label>Page-level</label>
        <div class="chips">
          <span class="chip" id="sup-numberline" onclick="toggleSupport('numberline',this)">Number line</span>
        </div>
      </div>
    </div>
  </div>

  <div class="controls-row">
    <button class="btn-primary" onclick="generate()">Generate Sheet</button>
    <button class="btn-secondary" id="print-btn" disabled onclick="window.print()">Print / Save as PDF</button>
    <button class="btn-secondary" id="reshuffle-btn" style="display:none" onclick="generate()">Regenerate</button>
  </div>

  <div class="output-card" id="output-card" style="margin-top:1.25rem;">
    <div class="output-header">
      <span class="output-title">Fact Fluency Sheet</span>
      <span id="sheet-stats" style="font-size:12px;color:var(--text-hint);"></span>
    </div>
    <div class="sheet" id="sheet"></div>
    <div class="output-footer">
      <button class="btn-secondary" onclick="window.print()" style="font-size:12px;padding:6px 14px;">Print / Save as PDF</button>
      <button class="btn-secondary" onclick="generate()" style="font-size:12px;padding:6px 14px;">Regenerate</button>
    </div>
  </div>

</div>
<script>
  var op1 = '+';
  var op2 = 'none';
  var addMax = 5;   // sums up to
  var subMax = 5;   // differences within
  var supports = { fiveframe:false, tenframe1:false, tenframe2:false, tensones:false, numberline:false };



  function updateRangeVisibility(){
    var ops = [op1, op2];
    var hasAdd = ops.indexOf('+') !== -1;
    var hasSub = ops.indexOf('-') !== -1;
    document.getElementById('add-range-field').classList.toggle('visible', hasAdd);
    document.getElementById('sub-range-field').classList.toggle('visible', hasSub);
  }

  function pickOp(slot,op,el){
    var id = slot===1 ? '#op1-chips' : '#op2-chips';
    document.querySelectorAll(id+' .chip').forEach(function(c){c.classList.remove('on');});
    el.classList.add('on');
    if(slot===1) op1=op; else op2=op;
    updateRangeVisibility();
  }

  function pickRange(type, val, el){
    var id = type==='add' ? '#add-range-chips' : '#sub-range-chips';
    document.querySelectorAll(id+' .chip').forEach(function(c){c.classList.remove('on');});
    el.classList.add('on');
    if(type==='add') addMax=val; else subMax=val;
  }

  // frame supports are mutually exclusive group (fiveframe, tenframe1, tenframe2)
  var frameGroup = ['fiveframe','tenframe1','tenframe2'];
  function toggleSupport(key,el){
    if(frameGroup.indexOf(key) !== -1){
      frameGroup.forEach(function(k){
        if(k!==key && supports[k]){
          supports[k]=false;
          document.getElementById('sup-'+k).classList.remove('on');
        }
      });
    }
    supports[key]=!supports[key];
    el.classList.toggle('on',supports[key]);
  }

  function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
  function shuffle(arr){
    var a=arr.slice();
    for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;}
    return a;
  }

  // Generate pairs for + within a sum limit
  function addPairs(max){
    var pairs=[];
    for(var a=0;a<=max;a++) for(var b=0;b<=max-a;b++) pairs.push([a,b]);
    return pairs;
  }
  // Generate pairs for - within a limit (minuend <= max)
  function subPairs(max){
    var pairs=[];
    for(var a=0;a<=max;a++) for(var b=0;b<=a;b++) pairs.push([a,b]);
    return pairs;
  }

  function makeProblem(op){
    var a,b,pair;
    if(op==='+'){
      pair=pick(addPairs(addMax));
      a=pair[0]; b=pair[1];
    } else {
      pair=pick(subPairs(subMax));
      a=pair[0]; b=pair[1];
    }
    return {a:a,b:b,op:op};
  }

  function oneFiveFrame(){
    var html='<div class="five-frame">';
    for(var i=0;i<5;i++) html+='<div class="tf-cell"></div>';
    return html+'</div>';
  }

  function oneTenFrame(){
    return '<div class="ten-frame">'+
      '<div class="tf-row"><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div></div>'+
      '<div class="tf-row"><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div><div class="tf-cell"></div></div>'+
      '</div>';
  }

  function renderFrames(){
    if(supports.fiveframe) return oneFiveFrame();
    if(supports.tenframe1) return '<div class="tf-wrap">'+oneTenFrame()+'</div>';
    if(supports.tenframe2) return '<div class="tf-wrap">'+oneTenFrame()+oneTenFrame()+'</div>';
    return '';
  }

  function renderTensOnes(){
    return '<div class="to-chart">'+
      '<div class="to-head">Tens</div><div class="to-head">Ones</div>'+
      '<div class="to-body">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div><div class="to-body">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>'+
      '</div>';
  }

  function renderNumberLine(max){
    var end=Math.min(max,20);
    var html='<div class="number-line-wrap"><div class="number-line">';
    for(var i=0;i<=end;i++) html+='<div class="nl-tick">'+i+'</div>';
    return html+'</div></div>';
  }

  var spacingMap = {
    compact: { rowGap:'0.5rem', colGap:'0.75rem' },
    normal:  { rowGap:'1rem',   colGap:'1rem' },
    spread:  { rowGap:'1.8rem', colGap:'1rem' },
    full:    { rowGap:'1rem',   colGap:'1rem' }
  };

  function generate(){
    var count   = parseInt(document.getElementById('prob-count').value)||12;
    var cols    = parseInt(document.getElementById('layout').value)||3;
    var spacing = document.getElementById('spacing').value;

    var ops = op2==='none' ? [op1] : [op1,op2];
    var problems=[];
    for(var i=0;i<count;i++) problems.push(makeProblem(ops[i%ops.length]));
    problems=shuffle(problems);

    // Number line max: for + use addMax, for - use subMax, otherwise activeNums
    var nlMax=20;
    if(ops.length===1){
      if(op1==='+') nlMax=addMax;
      else if(op1==='-') nlMax=subMax;
    }

    var sp=spacingMap[spacing]||spacingMap.normal;
    var html='';

    // Sheet header
    html+='<div class="sheet-header">';
    html+='<div class="sheet-header-field"><span>Name:</span><span class="sheet-header-line shl-name"></span></div>';
    html+='<div class="sheet-header-field"><span>Date:</span><span class="sheet-header-line shl-date"></span></div>';
    html+='</div>';

    // Skill label
    var skillParts = [];
    ops.forEach(function(o){
      if(o==='+') skillParts.push('Addition — Sums to '+addMax);
      else if(o==='-') skillParts.push('Subtraction — Within '+subMax);
    });
    html+='<div class="sheet-label">'+skillParts.join(' / ')+'</div>';

    // Page-level supports
    if(supports.numberline) html+='<div class="support-block">'+renderNumberLine(nlMax)+'</div>';

    // Problem grid
    var gridClass='problem-grid';
    if(spacing==='full') gridClass+=' spacing-fill';
    else if(spacing==='spread') gridClass+=' spacing-spread';
    var gridStyle='grid-template-columns:repeat('+cols+',1fr);row-gap:'+sp.rowGap+';column-gap:'+sp.colGap+';';
    html+='<div class="'+gridClass+'" style="'+gridStyle+'">';

    problems.forEach(function(p){
      html+='<div class="prob-cell">';
      html+='<div class="equation">';
      html+='<span class="eq-num">'+p.a+'</span>';
      html+='<span class="eq-op">'+p.op+'</span>';
      html+='<span class="eq-num">'+p.b+'</span>';
      html+='<span style="font-weight:300;color:var(--text-secondary);">=</span>';
      html+='<span class="eq-ans"></span>';
      html+='</div>';
      html+=renderFrames();
      if(supports.tensones) html+=renderTensOnes();
      html+='</div>';
    });

    html+='</div>';

    document.getElementById('sheet').innerHTML=html;

    var rangeLabel='';
    if(ops.indexOf('+')!==-1) rangeLabel+=' · + sums to '+addMax;
    if(ops.indexOf('-')!==-1) rangeLabel+=' · − within '+subMax;
    document.getElementById('sheet-stats').textContent=count+' problems · '+ops.join(' / ')+rangeLabel;

    document.getElementById('output-card').style.display='block';
    document.getElementById('print-btn').disabled=false;
    document.getElementById('reshuffle-btn').style.display='inline-block';
    document.getElementById('output-card').scrollIntoView({behavior:'smooth',block:'start'});
  }
</script>
</body>
</html>
